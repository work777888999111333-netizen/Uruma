                    <button class="btn btn-outline-white btn-sm" onclick="logout()">Выйти</button>
                </span>
                <button class="btn btn-red" onclick="switchTab('report')">🚨 Сообщить</button>
            </div>
        </div>
        <div class="nav-bar">
            <div class="nav-inner">
                <a onclick="switchTab('all')" id="nav-all" class="active">Все мошенники</a>
                <a onclick="switchTab('pyramid')" id="nav-pyramid">Пирамиды</a>
                <a onclick="switchTab('broker')" id="nav-broker">Брокеры</a>
                <a onclick="switchTab('crypto')" id="nav-crypto">Крипто</a>
                <a onclick="switchTab('nft')" id="nav-nft" class="nft-tab">🎨 NFT-скам</a>
                <a onclick="switchTab('phishing')" id="nav-phishing">Фишинг</a>
            </div>
        </div>
    </header>

    <div class="modal-overlay" id="loginModal">
        <div class="modal-dialog">
            <button class="modal-close" onclick="closeModal('loginModal')">✕</button>
            <h2>Вход</h2>
            <div class="field"><label>Логин</label><input type="text" id="loginUser" placeholder="Введите логин"></div>
            <div class="field"><label>Пароль</label><input type="password" id="loginPass" placeholder="Введите пароль"></div>
            <p class="modal-error" id="loginErr">Неверный логин или пароль</p>
            <button class="btn btn-red" style="width:100%;" onclick="doLogin()">Войти</button>
            <p class="modal-link">Нет аккаунта? <a onclick="closeModal('loginModal'); openModal('regModal')">Регистрация</a></p>
        </div>
    </div>

    <div class="modal-overlay" id="regModal">
        <div class="modal-dialog">
            <button class="modal-close" onclick="closeModal('regModal')">✕</button>
            <h2>Регистрация</h2>
            <div class="field"><label>Придумайте логин</label><input type="text" id="regUser" placeholder="Логин"></div>
            <div class="field"><label>Придумайте пароль</label><input type="password" id="regPass" placeholder="Пароль"></div>
            <p class="modal-error" id="regErr">Пользователь уже существует</p>
            <button class="btn btn-red" style="width:100%;" onclick="doRegister()">Зарегистрироваться</button>
            <p class="modal-link">Уже есть аккаунт? <a onclick="closeModal('regModal'); openModal('loginModal')">Войти</a></p>
        </div>
    </div>

    <div class="main-container">

        <div class="stats-bar">
            <div class="stat-item">
                <div class="stat-num" id="statTotal">0</div>
                <div class="stat-label">Всего в базе</div>
            </div>
            <div class="stat-item">
                <div class="stat-num" id="
